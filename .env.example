# VikiLeads — Environment Variables
# Copy: cp .env.example apps/api/.env
# Generate JWT_SECRET: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ────────────────────────────────────────────
# Dev: PostgreSQL direct (5432). Prod: PgBouncer (6432).
DATABASE_URL=postgresql://vikileads:vikileads_dev@localhost:5432/vikileads

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (Dashboard JWT) ───────────────────────────────
JWT_SECRET=

# ─── Frontend ────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Profile Limits (Extension) ─────────────────────────
# Chrome profiles per user. Change without code changes.
MAX_PROFILES_FREE=2
MAX_PROFILES_UNLIMITED=3

# ─── Dodo Payments ───────────────────────────────────────
DODO_API_KEY=
DODO_WEBHOOK_SECRET=

# ─── Resend (Email) ─────────────────────────────────────
RESEND_API_KEY=

# ─── Sentry ─────────────────────────────────────────────
SENTRY_DSN=

# ─── Enricher Service (External) ────────────────────────
ENRICHER_URL=http://localhost:4001/enrich
ENRICHER_SECRET=

# ─── Cleaner Service (External) ─────────────────────────
CLEANER_URL=http://localhost:4002/clean
CLEANER_SECRET=


# ─── Database Pool ───────────────────────────────────────
# Dev: keep defaults. Prod: tune based on PgBouncer + PM2 instances.
# With PM2 × 4 processes: 4 × 20 = 80 total connections to PgBouncer.
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=5000