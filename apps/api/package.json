{
  "name": "@vikileads/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate:up": "node-pg-migrate up --database-url-var DATABASE_URL --migrations-dir src/db/migrations",
    "migrate:down": "node-pg-migrate down --database-url-var DATABASE_URL --migrations-dir src/db/migrations",
    "migrate:create": "node-pg-migrate create --migrations-dir src/db/migrations",
    "test": "jest --runInBand --forceExit"
  },
  "dependencies": {
    "@vikileads/shared": "*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "node-pg-migrate": "^7.7.0",
    "pg": "^8.13.0",
    "pg-cursor": "^2.12.0",
    "bcrypt": "^6.0.0",
"jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
